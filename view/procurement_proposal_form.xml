<?xml version="1.0"?>
<form>
    <group id="main" col="4" colspan="4">
        <label name="round"/>
        <field name="round"/>
        <label name="party"/>
        <field name="party"/>
        <label name="state"/>
        <field name="state"/>
        <label name="request_generated"/>
        <field name="request_generated"/>
        <label name="request_generated_date"/>
        <field name="request_generated_date"/>
        <label name="request_generated_by"/>
        <field name="request_generated_by"/>
        <label name="has_response_file"/>
        <field name="has_response_file"/>
        <label name="response_received_date"/>
        <field name="response_received_date"/>
        <label name="response_received_by"/>
        <field name="response_received_by"/>
        <label name="is_winner"/>
        <field name="is_winner"/>
        <label name="purchase"/>
        <field name="purchase"/>
    </group>
    <group id="response" col="4" colspan="4">
        <label name="response_filename"/>
        <field name="response_filename"/>
        <label name="response_file"/>
        <field name="response_file"/>
    </group>
    <label name="observations"/>
    <field name="observations" colspan="4"/>
    <group id="actions" string="Acciones" colspan="4" col="2">
        <button name="generate_budget_request"
                string="Generar Solicitud"
                icon="tryton-print"/>
        <button name="mark_as_winner"
                string="Marcar Ganadora"
                icon="tryton-ok"/>
    </group>
</form>
